	measure 'Periodo Anterior' =
			
			CALCULATE(
			    [Total Vendas],
			    SAMEPERIODLASTYEAR('Tabela Calendário'[Date])
			)
		formatString: "R$"\ #,0.###############;-"R$"\ #,0.###############;"R$"\ #,0.###############
		lineageTag: 30947d79-56e4-4746-a42f-d0acb5f2e92d

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure YoY = ```
			
			    DIVIDE(
			        [Total Vendas] - [Periodo Anterior],
			        [Periodo Anterior]
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: aa19cfbd-787a-4af2-aa24-78d21b5bfb66

