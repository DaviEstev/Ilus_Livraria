	partition 'Tabela Calendário' = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDARAUTO(),
				    "Dia num", DAY([Date]),
				    "Dia nome", FORMAT([Date], "dddd"),
				    "Dia Semana", WEEKDAY([Date]),
				    "Semana Num", WEEKNUM([Date]),
				    "Mês Num", MONTH([Date]),
				    "Mês Nome", FORMAT([Date], "mmm"),
				    "Trimestre", QUARTER([Date]),
				    "Ano", YEAR([Date])
				)

	annotation PBI_Id = 632dbd44ae4d45f5ba94383c4a132816

